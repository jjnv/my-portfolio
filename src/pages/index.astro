---
import ArrowIcon from '../components/ArrowIcon.astro';
import ProjectDiagram from '../components/ProjectDiagram.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { education, experience, profile, projects, skillGroups } from '../data/portfolio';

const description =
  'Explore the Linux-inspired portfolio of Juanjo Navarro, a Barcelona-based Data Engineer building reliable data platforms, observability systems and practical AI tools.';

const projectPaths = {
  'airflow-observer': '~/projects/airflow-observer/README.md',
  'llm-eval-lab': '~/projects/llm-eval-lab/README.md',
  boundedscan: '~/projects/boundedscan/README.md'
} as const;
---

<BaseLayout title="Juanjo Navarro — Data Engineer" description={description}>
  <div class="boot-screen" data-boot>
    <div class="boot-screen__terminal">
      <div class="boot-screen__brand">
        <span class="boot-screen__mark">JN</span>
        <span>JUANJO/OS</span>
        <span>v1.0.0</span>
      </div>
      <div class="boot-screen__log" aria-hidden="true">
        <p><span>[ <i>OK</i> ]</span> Mounted /home/juanjo</p>
        <p><span>[ <i>OK</i> ]</span> Loaded data-engineering.service</p>
        <p><span>[ <i>OK</i> ]</span> Started portfolio interface</p>
      </div>
      <div class="boot-screen__progress"><i></i></div>
      <div class="boot-screen__footer">
        <span>BOOTING WORKSTATION</span>
        <button type="button" data-skip-boot>Skip <kbd>Esc</kbd></button>
      </div>
    </div>
  </div>

  <div class="os-shell">
    <header class="system-bar">
      <a class="system-bar__identity" href="#home" data-open="home" aria-label="Open home">
        <span class="system-bar__logo">JN</span>
        <span>juanjo@portfolio</span>
      </a>
      <div class="system-bar__workspace" aria-hidden="true">
        <span>01</span>
        <i></i>
        <span>OPS WORKSTATION</span>
      </div>
      <div class="system-bar__status">
        <span class="availability"><i></i> AVAILABLE</span>
        <time data-clock>--:--</time>
      </div>
    </header>

    <main class="workstation" id="main-content">
      <section
        class="terminal-window window"
        id="terminal-panel"
        aria-labelledby="terminal-title"
      >
        <div class="window__bar">
          <div class="window__controls" aria-hidden="true">
            <i></i><i></i><i></i>
          </div>
          <span id="terminal-title">terminal — juanjo@portfolio:~</span>
          <span class="window__meta">bash</span>
        </div>

        <div class="terminal" data-terminal>
          <div class="terminal__output" data-terminal-output aria-live="polite" aria-atomic="false">
            <div class="terminal__block terminal__welcome">
              <pre aria-hidden="true">
     ██╗███╗   ██╗
     ██║████╗  ██║
     ██║██╔██╗ ██║
██   ██║██║╚██╗██║
╚█████╔╝██║ ╚████║
 ╚════╝ ╚═╝  ╚═══╝</pre
              >
              <div>
                <strong>Juanjo Navarro / Data Engineer</strong>
                <span>Reliable data. Useful systems.</span>
                <span class="terminal__muted">Barcelona, Spain · portfolio build 2026.07</span>
              </div>
            </div>
            <p class="terminal__line">
              Type <button type="button" data-command="help">help</button> or choose a command below.
            </p>
          </div>

          <form class="terminal__form" data-terminal-form autocomplete="off">
            <label class="sr-only" for="terminal-input">Portfolio terminal command</label>
            <span class="terminal__prompt" data-prompt>juanjo@portfolio:~$</span>
            <input
              id="terminal-input"
              name="command"
              type="text"
              inputmode="text"
              spellcheck="false"
              autocapitalize="off"
              aria-describedby="terminal-hint"
              data-terminal-input
            />
            <span class="terminal__cursor" aria-hidden="true"></span>
          </form>
          <p class="sr-only" id="terminal-hint">
            Available commands include help, whoami, neofetch, ls, cd, cat, open, history and clear.
          </p>
        </div>

        <div class="quick-commands" aria-label="Quick terminal commands">
          <span>QUICK COMMANDS</span>
          <div>
            <button type="button" data-command="whoami">whoami</button>
            <button type="button" data-command="ls projects">ls projects/</button>
            <button type="button" data-command="neofetch">neofetch</button>
            <button type="button" data-command="open contact">contact</button>
          </div>
        </div>
      </section>

      <section
        class="workspace-window window"
        id="portfolio-panel"
        aria-label="Portfolio file viewer"
      >
        <div class="window__bar">
          <div class="window__controls" aria-hidden="true">
            <i></i><i></i><i></i>
          </div>
          <span data-window-title>README.md — portfolio</span>
          <span class="window__meta" data-workspace-index>01 / HOME</span>
        </div>

        <div class="workspace">
          <nav class="file-tree" aria-label="Portfolio files">
            <div class="file-tree__heading">
              <span>EXPLORER</span>
              <span>···</span>
            </div>
            <div class="file-tree__root">
              <button type="button" class="tree-row tree-row--root" data-path="~" data-directory>
                <span>⌄</span><strong>JUANJO</strong>
              </button>
              <button type="button" class="tree-row" data-path="~/README.md">
                <span class="tree-icon tree-icon--md">M↓</span>README.md
              </button>
              <button type="button" class="tree-row" data-path="~/profile.md">
                <span class="tree-icon tree-icon--md">M↓</span>profile.md
              </button>
              <button
                type="button"
                class="tree-row tree-row--folder"
                data-path="~/projects"
                data-directory
              >
                <span>⌄</span><span class="tree-icon tree-icon--folder"></span>projects
              </button>
              {
                projects.map((project) => (
                  <button
                    type="button"
                    class="tree-row tree-row--nested"
                    data-path={projectPaths[project.slug]}
                  >
                    <span class="tree-icon tree-icon--md">M↓</span>
                    {project.slug}.md
                  </button>
                ))
              }
              <button type="button" class="tree-row" data-path="~/experience/vueling.service">
                <span class="tree-icon tree-icon--service">⚙</span>experience.service
              </button>
              <button type="button" class="tree-row" data-path="~/stack/packages.txt">
                <span class="tree-icon tree-icon--txt">#</span>packages.txt
              </button>
              <button type="button" class="tree-row" data-path="~/education/transcript.md">
                <span class="tree-icon tree-icon--md">M↓</span>education.md
              </button>
              <button type="button" class="tree-row" data-path="~/contact.txt">
                <span class="tree-icon tree-icon--txt">@</span>contact.txt
              </button>
            </div>
          </nav>

          <div class="document-pane" data-document-pane>
            <div class="document-tabs" aria-hidden="true">
              <span class="is-active" data-document-tab>README.md <i>×</i></span>
              <span class="document-tabs__spacer"></span>
              <span>UTF-8</span>
            </div>

            <div class="document-scroll">
              <article
                class="document-view document-view--home is-active"
                data-view="home"
                data-title="README.md — portfolio"
                data-index="01 / HOME"
                id="home"
              >
                <div class="document-view__eyebrow">
                  <span>~/README.md</span>
                  <span class="status-pill"><i></i> SYSTEM ONLINE</span>
                </div>
                <div class="home-hero">
                  <div>
                    <p class="code-comment"># DATA ENGINEER · BARCELONA</p>
                    <h1>Reliable data.<br /><em>Useful systems.</em></h1>
                    <p class="home-hero__intro">
                      I’m Juanjo, a data engineer turning operational complexity into dependable
                      pipelines, clear signals and tools teams can act on.
                    </p>
                    <div class="document-actions">
                      <button type="button" class="action-button" data-open="projects">
                        Explore work <ArrowIcon />
                      </button>
                      <a class="text-action" href={`mailto:${profile.email}`}>
                        Get in touch <ArrowIcon />
                      </a>
                    </div>
                  </div>
                  <div class="system-card" aria-label="Current system status">
                    <div class="system-card__head">
                      <span>pipeline.service</span>
                      <span>● active</span>
                    </div>
                    <div class="system-card__flow" aria-hidden="true">
                      <span>SOURCE</span><i></i><b>01</b><i></i><b>02</b><i></i><b>03</b><i></i
                      ><span>SIGNAL</span>
                    </div>
                    <dl>
                      <div><dt>ingest</dt><dd>healthy</dd></div>
                      <div><dt>model</dt><dd>healthy</dd></div>
                      <div><dt>observe</dt><dd>healthy</dd></div>
                    </dl>
                  </div>
                </div>

                <div class="metric-grid">
                  <article>
                    <span>PROCESSING</span>
                    <strong>−20<sup>%</sup></strong>
                    <p>Processing time and data volume after redesigning incremental extraction.</p>
                  </article>
                  <article>
                    <span>INCIDENT RESPONSE</span>
                    <strong>−30<sup>%</sup></strong>
                    <p>Detection and resolution time through stronger production observability.</p>
                  </article>
                  <article class="metric-grid__principle">
                    <span>OPERATING PRINCIPLE</span>
                    <p>Data only matters when people can trust it.</p>
                    <small>Built for the moment something goes wrong.</small>
                  </article>
                </div>

                <section class="home-projects" aria-labelledby="home-projects-title">
                  <div class="section-label">
                    <span id="home-projects-title">SELECTED WORK</span>
                    <span>03 repositories</span>
                  </div>
                  {
                    projects.map((project) => (
                      <button
                        class="project-row"
                        type="button"
                        data-open={`project-${project.slug}`}
                      >
                        <span class="project-row__number">{project.number}</span>
                        <span>
                          <strong>{project.title}</strong>
                          <small>{project.eyebrow}</small>
                        </span>
                        <span class="project-row__stack">{project.stack.slice(0, 3).join(' / ')}</span>
                        <ArrowIcon />
                      </button>
                    ))
                  }
                </section>
              </article>

              <article
                class="document-view"
                data-view="about"
                data-title="profile.md — portfolio"
                data-index="02 / PROFILE"
                id="about"
              >
                <div class="document-view__eyebrow">
                  <span>~/profile.md</span><span>whoami</span>
                </div>
                <header class="document-header">
                  <p class="code-comment"># USER PROFILE</p>
                  <h2>Juanjo<br />Navarro.</h2>
                  <p>
                    Data Engineer focused on reliable pipelines, observable platforms and
                    production systems that turn complexity into useful decisions.
                  </p>
                </header>
                <div class="profile-grid">
                  <dl class="profile-spec">
                    <div><dt>ROLE</dt><dd>{profile.role}</dd></div>
                    <div><dt>LOCATION</dt><dd>{profile.location}</dd></div>
                    <div><dt>FOCUS</dt><dd>Data platforms / Reliability / Applied AI</dd></div>
                    <div><dt>STATUS</dt><dd><span class="status-dot"></span>Available to connect</dd></div>
                  </dl>
                  <div class="profile-manifesto">
                    <span>OPERATING PRINCIPLE / 01</span>
                    <blockquote>
                      I don’t just move data.<br /><em>I make it trustworthy.</em>
                    </blockquote>
                    <p>
                      Observable by design. Reproducible by default. Useful to humans.
                    </p>
                  </div>
                </div>
              </article>

              <article
                class="document-view"
                data-view="projects"
                data-title="projects — portfolio"
                data-index="03 / PROJECTS"
                id="projects"
              >
                <div class="document-view__eyebrow">
                  <span>~/projects/</span><span>3 entries</span>
                </div>
                <header class="document-header">
                  <p class="code-comment"># SELECTED OPEN-SOURCE WORK</p>
                  <h2>Systems built<br /><em>to be used.</em></h2>
                  <p>
                    Projects spanning data reliability, reproducible AI evaluation and defensive
                    security engineering.
                  </p>
                </header>
                <div class="project-directory">
                  {
                    projects.map((project) => (
                      <button type="button" data-open={`project-${project.slug}`}>
                        <span>{project.number}</span>
                        <div>
                          <small>{project.eyebrow}</small>
                          <strong>{project.title}</strong>
                          <p>{project.description}</p>
                          <ul aria-label={`${project.title} technologies`}>
                            {project.stack.map((technology) => <li>{technology}</li>)}
                          </ul>
                        </div>
                        <ArrowIcon />
                      </button>
                    ))
                  }
                </div>
              </article>

              {
                projects.map((project) => (
                  <article
                    class="document-view project-document"
                    data-view={`project-${project.slug}`}
                    data-title={`${project.slug}.md — portfolio`}
                    data-index={`${project.number} / PROJECT`}
                    id={`project-${project.slug}`}
                  >
                    <div class="document-view__eyebrow">
                      <span>{projectPaths[project.slug]}</span>
                      <span class="status-pill"><i></i> OPEN SOURCE</span>
                    </div>
                    <header class="project-document__header">
                      <div>
                        <p class="code-comment"># {project.eyebrow.toUpperCase()}</p>
                        <h2>{project.title}</h2>
                        <p>{project.description}</p>
                      </div>
                      <span class="project-document__number">{project.number}</span>
                    </header>
                    <div class="project-document__diagram">
                      <div class="diagram-label">
                        <span>ARCHITECTURE / SYSTEM VIEW</span><span>LIVE SPEC</span>
                      </div>
                      <ProjectDiagram type={project.slug} />
                    </div>
                    <div class="case-study-grid">
                      <section>
                        <span>01 / PROBLEM</span>
                        <h3>Operational complexity needs a legible interface.</h3>
                        <p>{project.impact}</p>
                      </section>
                      <section>
                        <span>02 / SYSTEM</span>
                        <h3>Built around real workflows, not a demo path.</h3>
                        <p>{project.description}</p>
                      </section>
                      <section class="case-study-grid__stack">
                        <span>03 / TOOLCHAIN</span>
                        <ul>
                          {project.stack.map((technology) => <li>{technology}</li>)}
                        </ul>
                      </section>
                    </div>
                    <a class="repository-link" href={project.href} target="_blank" rel="noreferrer">
                      <span>
                        <small>VIEW SOURCE</small>
                        github.com/jjnv/{project.title.replaceAll(' ', '-')}
                      </span>
                      <ArrowIcon />
                      <span class="sr-only"> for {project.title} (opens in a new tab)</span>
                    </a>
                  </article>
                ))
              }

              <article
                class="document-view"
                data-view="experience"
                data-title="vueling.service — portfolio"
                data-index="04 / EXPERIENCE"
                id="experience"
              >
                <div class="document-view__eyebrow">
                  <span>~/experience/vueling.service</span>
                  <span class="status-pill"><i></i> ACTIVE (RUNNING)</span>
                </div>
                <header class="document-header">
                  <p class="code-comment"># SYSTEMCTL STATUS EXPERIENCE</p>
                  <h2>In production,<br /><em>every day.</em></h2>
                </header>
                {
                  experience.map((role) => (
                    <section class="service-card">
                      <div class="service-card__summary">
                        <div><span>●</span><strong>{role.company}</strong></div>
                        <dl>
                          <div><dt>Loaded:</dt><dd>loaded; enabled</dd></div>
                          <div><dt>Active:</dt><dd>active (running)</dd></div>
                          <div><dt>Since:</dt><dd>{role.period}</dd></div>
                          <div><dt>Location:</dt><dd>{role.location}</dd></div>
                        </dl>
                      </div>
                      <div class="service-card__role">
                        <small>MAIN PROCESS</small>
                        <h3>{role.role}</h3>
                        <p>{role.summary}</p>
                      </div>
                      <ol class="service-log">
                        {role.achievements.map((achievement, index) => (
                          <li>
                            <time>{String(index + 1).padStart(2, '0')}:00</time>
                            <span>portfolio[{1100 + index}]</span>
                            <p>{achievement}</p>
                          </li>
                        ))}
                      </ol>
                    </section>
                  ))
                }
              </article>

              <article
                class="document-view"
                data-view="stack"
                data-title="packages.txt — portfolio"
                data-index="05 / STACK"
                id="stack"
              >
                <div class="document-view__eyebrow">
                  <span>~/stack/packages.txt</span><span>dependencies resolved</span>
                </div>
                <header class="document-header">
                  <p class="code-comment"># INSTALLED PACKAGES</p>
                  <h2>Tools chosen<br /><em>with intent.</em></h2>
                  <p>
                    A practical toolkit for moving data, shipping models and keeping production
                    systems understandable.
                  </p>
                </header>
                <div class="package-grid">
                  {
                    skillGroups.map((group) => (
                      <section>
                        <div><span>{group.index}</span><h3>{group.title}</h3></div>
                        <ul>
                          {group.skills.map((skill, index) => (
                            <li><span>{String(index + 1).padStart(2, '0')}</span>{skill}<i>installed</i></li>
                          ))}
                        </ul>
                      </section>
                    ))
                  }
                </div>
              </article>

              <article
                class="document-view"
                data-view="education"
                data-title="transcript.md — portfolio"
                data-index="06 / EDUCATION"
                id="education"
              >
                <div class="document-view__eyebrow">
                  <span>~/education/transcript.md</span><span>verified history</span>
                </div>
                <header class="document-header">
                  <p class="code-comment"># EDUCATION LOG</p>
                  <h2>Mathematical roots.<br /><em>Engineering focus.</em></h2>
                </header>
                <div class="education-log">
                  {
                    education.map((item, index) => (
                      <section>
                        <span class="education-log__index">0{index + 1}</span>
                        <div>
                          <time>{item.period}</time>
                          <h3>{item.qualification}</h3>
                          <p>{item.institution}</p>
                          {item.detail && <small>{item.detail}</small>}
                        </div>
                        <span class="education-log__status">COMPLETE / ACTIVE</span>
                      </section>
                    ))
                  }
                </div>
              </article>

              <article
                class="document-view contact-document"
                data-view="contact"
                data-title="contact.txt — portfolio"
                data-index="07 / CONTACT"
                id="contact"
              >
                <div class="document-view__eyebrow">
                  <span>~/contact.txt</span><span class="status-pill"><i></i> CONNECTION READY</span>
                </div>
                <div class="contact-document__content">
                  <p class="code-comment"># OPEN A CONNECTION</p>
                  <h2>Have a data problem<br /><em>worth solving?</em></h2>
                  <p>
                    I’m always interested in reliable systems, ambitious data platforms and
                    thoughtful engineering conversations.
                  </p>
                  <a class="contact-email" href={`mailto:${profile.email}`}>
                    <span>MAIL</span>{profile.email}<ArrowIcon />
                  </a>
                  <div class="contact-links">
                    <a href={profile.github} target="_blank" rel="noreferrer">
                      <span>01</span><strong>GitHub</strong><small>github.com/jjnv ↗</small>
                    </a>
                    <a href={profile.linkedin} target="_blank" rel="noreferrer">
                      <span>02</span><strong>LinkedIn</strong><small>Connect professionally ↗</small>
                    </a>
                  </div>
                </div>
              </article>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="system-footer">
      <div class="system-footer__desktop">
        <span><i></i> main*</span>
        <span>Astro 7.1.1</span>
        <span>UTF-8</span>
        <span class="system-footer__path" data-footer-path>~/README.md</span>
        <span>Ln 1, Col 1</span>
        <span>© {new Date().getFullYear()} JN</span>
      </div>
      <nav class="mobile-view-switcher" aria-label="Mobile workspace">
        <button
          type="button"
          data-mobile-show="document"
          aria-controls="portfolio-panel"
          aria-pressed="true"
        >
          <span aria-hidden="true">▤</span>
          Portfolio
        </button>
        <button
          type="button"
          data-mobile-show="terminal"
          aria-controls="terminal-panel"
          aria-pressed="false"
        >
          <span aria-hidden="true">&gt;_</span>
          Terminal
        </button>
      </nav>
    </footer>
  </div>

  <script>
    type ViewName =
      | 'home'
      | 'about'
      | 'projects'
      | 'project-airflow-observer'
      | 'project-llm-eval-lab'
      | 'project-boundedscan'
      | 'experience'
      | 'stack'
      | 'education'
      | 'contact';

    type FileEntry = {
      name: string;
      path: string;
      kind: 'file' | 'directory';
      view?: ViewName;
    };

    const files: Record<string, FileEntry[]> = {
      '~': [
        { name: 'README.md', path: '~/README.md', kind: 'file', view: 'home' },
        { name: 'profile.md', path: '~/profile.md', kind: 'file', view: 'about' },
        { name: 'projects/', path: '~/projects', kind: 'directory', view: 'projects' },
        { name: 'experience/', path: '~/experience', kind: 'directory', view: 'experience' },
        { name: 'stack/', path: '~/stack', kind: 'directory', view: 'stack' },
        { name: 'education/', path: '~/education', kind: 'directory', view: 'education' },
        { name: 'contact.txt', path: '~/contact.txt', kind: 'file', view: 'contact' }
      ],
      '~/projects': [
        {
          name: 'airflow-observer/',
          path: '~/projects/airflow-observer',
          kind: 'directory',
          view: 'project-airflow-observer'
        },
        {
          name: 'llm-eval-lab/',
          path: '~/projects/llm-eval-lab',
          kind: 'directory',
          view: 'project-llm-eval-lab'
        },
        {
          name: 'boundedscan/',
          path: '~/projects/boundedscan',
          kind: 'directory',
          view: 'project-boundedscan'
        }
      ],
      '~/experience': [
        {
          name: 'vueling.service',
          path: '~/experience/vueling.service',
          kind: 'file',
          view: 'experience'
        }
      ],
      '~/stack': [
        { name: 'packages.txt', path: '~/stack/packages.txt', kind: 'file', view: 'stack' }
      ],
      '~/education': [
        {
          name: 'transcript.md',
          path: '~/education/transcript.md',
          kind: 'file',
          view: 'education'
        }
      ],
      '~/projects/airflow-observer': [
        {
          name: 'README.md',
          path: '~/projects/airflow-observer/README.md',
          kind: 'file',
          view: 'project-airflow-observer'
        }
      ],
      '~/projects/llm-eval-lab': [
        {
          name: 'README.md',
          path: '~/projects/llm-eval-lab/README.md',
          kind: 'file',
          view: 'project-llm-eval-lab'
        }
      ],
      '~/projects/boundedscan': [
        {
          name: 'README.md',
          path: '~/projects/boundedscan/README.md',
          kind: 'file',
          view: 'project-boundedscan'
        }
      ]
    };

    const pathToView: Record<string, ViewName> = {
      '~': 'home',
      '~/README.md': 'home',
      '~/profile.md': 'about',
      '~/projects': 'projects',
      '~/projects/airflow-observer': 'project-airflow-observer',
      '~/projects/airflow-observer/README.md': 'project-airflow-observer',
      '~/projects/llm-eval-lab': 'project-llm-eval-lab',
      '~/projects/llm-eval-lab/README.md': 'project-llm-eval-lab',
      '~/projects/boundedscan': 'project-boundedscan',
      '~/projects/boundedscan/README.md': 'project-boundedscan',
      '~/experience': 'experience',
      '~/experience/vueling.service': 'experience',
      '~/stack': 'stack',
      '~/stack/packages.txt': 'stack',
      '~/education': 'education',
      '~/education/transcript.md': 'education',
      '~/contact.txt': 'contact'
    };

    const viewToPath: Record<ViewName, string> = {
      home: '~/README.md',
      about: '~/profile.md',
      projects: '~/projects',
      'project-airflow-observer': '~/projects/airflow-observer/README.md',
      'project-llm-eval-lab': '~/projects/llm-eval-lab/README.md',
      'project-boundedscan': '~/projects/boundedscan/README.md',
      experience: '~/experience/vueling.service',
      stack: '~/stack/packages.txt',
      education: '~/education/transcript.md',
      contact: '~/contact.txt'
    };

    const aliases: Record<string, ViewName> = {
      home: 'home',
      readme: 'home',
      about: 'about',
      profile: 'about',
      projects: 'projects',
      work: 'projects',
      'airflow-observer': 'project-airflow-observer',
      airflow: 'project-airflow-observer',
      'llm-eval-lab': 'project-llm-eval-lab',
      llm: 'project-llm-eval-lab',
      boundedscan: 'project-boundedscan',
      experience: 'experience',
      stack: 'stack',
      education: 'education',
      contact: 'contact'
    };

    const viewElements = Array.from(document.querySelectorAll<HTMLElement>('[data-view]'));
    const terminalOutput = document.querySelector<HTMLElement>('[data-terminal-output]');
    const terminalForm = document.querySelector<HTMLFormElement>('[data-terminal-form]');
    const terminalInput = document.querySelector<HTMLInputElement>('[data-terminal-input]');
    const prompt = document.querySelector<HTMLElement>('[data-prompt]');
    const terminal = document.querySelector<HTMLElement>('[data-terminal]');
    const windowTitle = document.querySelector<HTMLElement>('[data-window-title]');
    const documentTab = document.querySelector<HTMLElement>('[data-document-tab]');
    const workspaceIndex = document.querySelector<HTMLElement>('[data-workspace-index]');
    const footerPath = document.querySelector<HTMLElement>('[data-footer-path]');
    const mobilePanelButtons = Array.from(
      document.querySelectorAll<HTMLButtonElement>('[data-mobile-show]')
    );
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    let cwd = '~';
    let commandHistory: string[] = [];
    let historyIndex = 0;

    const normalizePath = (rawPath: string): string => {
      const value = rawPath.trim().replace(/\/+$/, '');
      if (!value || value === '.') return cwd;
      if (value === '~' || value.startsWith('~/')) return value;
      if (value === '..') {
        if (cwd === '~') return '~';
        const parts = cwd.replace('~/', '').split('/');
        parts.pop();
        return parts.length ? `~/${parts.join('/')}` : '~';
      }
      if (value.startsWith('../')) {
        const parent: string = normalizePath('..');
        return `${parent}/${value.slice(3)}`.replace('~//', '~/');
      }
      return cwd === '~' ? `~/${value}` : `${cwd}/${value}`;
    };

    const setPrompt = () => {
      if (prompt) prompt.textContent = `juanjo@portfolio:${cwd}$`;
    };

    const appendLine = (
      content: string,
      className = 'terminal__line',
      command?: { label: string; value: string }
    ) => {
      if (!terminalOutput) return;
      const line = document.createElement('p');
      line.className = className;
      if (content) line.textContent = content;
      if (command) {
        const button = document.createElement('button');
        button.type = 'button';
        button.textContent = command.label;
        button.dataset.command = command.value;
        line.append(button);
      }
      terminalOutput.append(line);
    };

    const appendCommand = (command: string) => {
      appendLine(`juanjo@portfolio:${cwd}$ ${command}`, 'terminal__line terminal__line--command');
    };

    const scrollTerminal = () => {
      if (!terminal) return;
      terminal.scrollTop = terminal.scrollHeight;
    };

    const showMobilePanel = (panel: 'terminal' | 'document') => {
      document.body.classList.toggle('mobile-terminal-open', panel === 'terminal');
      mobilePanelButtons.forEach((button) => {
        button.setAttribute('aria-pressed', String(button.dataset.mobileShow === panel));
      });
    };

    const openView = (view: ViewName, updateUrl = true, showOnMobile = true) => {
      const activeView = viewElements.find((element) => element.dataset.view === view);
      if (!activeView) return;

      viewElements.forEach((element) => {
        const isActive = element === activeView;
        element.classList.toggle('is-active', isActive);
        element.hidden = !isActive;
      });

      const title = activeView.dataset.title ?? 'portfolio';
      const index = activeView.dataset.index ?? '';
      const path = viewToPath[view];
      if (windowTitle) windowTitle.textContent = title;
      if (documentTab) documentTab.innerHTML = `${title.split(' — ')[0]} <i>×</i>`;
      if (workspaceIndex) workspaceIndex.textContent = index;
      if (footerPath) footerPath.textContent = path;
      document.querySelectorAll<HTMLElement>('[data-path]').forEach((item) => {
        item.classList.toggle('is-current', item.dataset.path === path);
      });

      if (updateUrl && location.hash !== `#${view}`) {
        history.pushState({ view }, '', `#${view}`);
      }

      document.querySelector<HTMLElement>('[data-document-pane]')?.scrollTo({ top: 0 });
      if (showOnMobile && window.matchMedia('(max-width: 760px)').matches) {
        showMobilePanel('document');
      }
    };

    const openPath = (path: string) => {
      const normalized = normalizePath(path);
      const view = pathToView[normalized];
      if (!view) return false;
      openView(view);
      return true;
    };

    const printDirectory = (path: string) => {
      const entries = files[path];
      if (!entries) {
        appendLine(`ls: cannot access '${path}': No such directory`, 'terminal__line terminal__error');
        return;
      }
      entries.forEach((entry) => {
        appendLine('', `terminal__line terminal__entry terminal__entry--${entry.kind}`, {
          label: entry.name,
          value: entry.kind === 'directory' ? `cd ${entry.path}` : `cat ${entry.path}`
        });
      });
    };

    const printHelp = () => {
      appendLine('Available portfolio commands:', 'terminal__line terminal__success');
      const helpEntries: Array<[string, string]> = [
        ['whoami', 'Open the user profile'],
        ['neofetch', 'Show system and stack summary'],
        ['ls [path]', 'List portfolio files'],
        ['cd <path>', 'Change directory'],
        ['cat <file>', 'Read a portfolio document'],
        ['open <name>', 'Open a section or project'],
        ['history', 'Show command history'],
        ['clear', 'Clear terminal output']
      ];
      helpEntries.forEach(([name, detail]) => {
        appendLine(`${name.padEnd(18, ' ')}${detail}`, 'terminal__line terminal__help');
      });
    };

    const runCommand = (rawCommand: string) => {
      const command = rawCommand.trim();
      if (!command) return;
      commandHistory.push(command);
      historyIndex = commandHistory.length;
      appendCommand(command);

      const [nameRaw = '', ...args] = command.split(/\s+/);
      const name = nameRaw.toLowerCase();
      const argument = args.join(' ');

      if (name === 'help' || name === 'man') {
        printHelp();
      } else if (name === 'whoami') {
        appendLine('juanjo — Data Engineer · Barcelona, Spain', 'terminal__line terminal__success');
        openView('about');
      } else if (name === 'neofetch') {
        [
          'OS: Juanjo/OS 1.0',
          'Host: Data Engineering Portfolio',
          'Role: Data Engineer',
          'Location: Barcelona, Spain',
          'Stack: Python · SQL · Airflow · AWS',
          'Focus: Reliability · Observability · Applied AI',
          'Status: Available to connect'
        ].forEach((line) => appendLine(line, 'terminal__line terminal__neofetch'));
        openView('about');
      } else if (name === 'pwd') {
        appendLine(cwd);
      } else if (name === 'ls') {
        const target = normalizePath(argument || '.');
        printDirectory(target);
        if (pathToView[target]) openView(pathToView[target]);
      } else if (name === 'cd') {
        const target = normalizePath(argument || '~');
        if (files[target]) {
          cwd = target;
          setPrompt();
          const view = pathToView[target];
          if (view) openView(view);
          printDirectory(target);
        } else {
          appendLine(`cd: ${argument}: No such directory`, 'terminal__line terminal__error');
        }
      } else if (name === 'cat') {
        const target = normalizePath(argument);
        if (openPath(target)) {
          appendLine(`Opened ${target}`, 'terminal__line terminal__success');
        } else {
          appendLine(`cat: ${argument}: No such file`, 'terminal__line terminal__error');
        }
      } else if (name === 'open') {
        const target = argument.toLowerCase().replace(/\s+/g, '-');
        const view = aliases[target];
        if (view) {
          openView(view);
          appendLine(`Opened ${viewToPath[view]}`, 'terminal__line terminal__success');
        } else {
          appendLine(
            `open: '${argument}' not found. Try: open projects`,
            'terminal__line terminal__error'
          );
        }
      } else if (name === 'history') {
        commandHistory.forEach((entry, index) => {
          appendLine(`${String(index + 1).padStart(3, ' ')}  ${entry}`, 'terminal__line');
        });
      } else if (name === 'clear') {
        if (terminalOutput) terminalOutput.innerHTML = '';
      } else {
        appendLine(
          `${name}: command not found. Type 'help' for available commands.`,
          'terminal__line terminal__error'
        );
      }
      scrollTerminal();
    };

    terminalForm?.addEventListener('submit', (event) => {
      event.preventDefault();
      if (!terminalInput) return;
      runCommand(terminalInput.value);
      terminalInput.value = '';
    });

    terminalInput?.addEventListener('keydown', (event) => {
      if (event.key === 'ArrowUp') {
        event.preventDefault();
        historyIndex = Math.max(0, historyIndex - 1);
        terminalInput.value = commandHistory[historyIndex] ?? '';
      } else if (event.key === 'ArrowDown') {
        event.preventDefault();
        historyIndex = Math.min(commandHistory.length, historyIndex + 1);
        terminalInput.value = commandHistory[historyIndex] ?? '';
      } else if (event.key === 'Tab') {
        event.preventDefault();
        const value = terminalInput.value;
        const parts = value.split(/\s+/);
        const commands = ['help', 'whoami', 'neofetch', 'ls', 'cd', 'cat', 'open', 'history', 'clear'];
        if (parts.length === 1) {
          const partialCommand = parts[0] ?? '';
          const match = commands.find((command) => command.startsWith(partialCommand));
          if (match) terminalInput.value = match;
        } else {
          const partial = parts.at(-1) ?? '';
          const candidates = [
            ...Object.keys(aliases),
            ...(files[cwd] ?? []).map((entry) => entry.name.replace(/\/$/, ''))
          ];
          const match = candidates.find((candidate) => candidate.startsWith(partial));
          if (match) {
            parts[parts.length - 1] = match;
            terminalInput.value = parts.join(' ');
          }
        }
      }
    });

    document.addEventListener('click', (event) => {
      const target = event.target as HTMLElement;
      const commandButton = target.closest<HTMLButtonElement>('[data-command]');
      if (commandButton?.dataset.command) {
        runCommand(commandButton.dataset.command);
        terminalInput?.focus();
        return;
      }

      const pathButton = target.closest<HTMLButtonElement>('[data-path]');
      if (pathButton?.dataset.path) {
        const command = pathButton.hasAttribute('data-directory')
          ? `cd ${pathButton.dataset.path}`
          : `cat ${pathButton.dataset.path}`;
        runCommand(command);
        return;
      }

      const openButton = target.closest<HTMLElement>('[data-open]');
      const view = openButton?.dataset.open as ViewName | undefined;
      if (view && viewToPath[view]) openView(view);

      const mobilePanel = target.closest<HTMLButtonElement>('[data-mobile-show]');
      if (
        mobilePanel?.dataset.mobileShow === 'terminal' ||
        mobilePanel?.dataset.mobileShow === 'document'
      ) {
        showMobilePanel(mobilePanel.dataset.mobileShow);
      }
    });

    window.addEventListener('popstate', () => {
      const requestedView = location.hash.slice(1) as ViewName;
      openView(viewToPath[requestedView] ? requestedView : 'home', false);
    });

    const initialView = location.hash.slice(1) as ViewName;
    openView(viewToPath[initialView] ? initialView : 'home', false, Boolean(initialView));
    setPrompt();

    const clock = document.querySelector<HTMLTimeElement>('[data-clock]');
    const updateClock = () => {
      if (!clock) return;
      clock.textContent = new Intl.DateTimeFormat('en-GB', {
        hour: '2-digit',
        minute: '2-digit',
        hour12: false
      }).format(new Date());
    };
    updateClock();
    window.setInterval(updateClock, 30000);

    const boot = document.querySelector<HTMLElement>('[data-boot]');
    const finishBoot = () => {
      if (!boot || boot.classList.contains('boot-screen--complete')) return;
      boot.classList.add('boot-screen--complete');
      window.setTimeout(() => boot.remove(), reduceMotion ? 0 : 550);
      sessionStorage.setItem('jn-os-booted', 'true');
    };

    if (reduceMotion || sessionStorage.getItem('jn-os-booted')) {
      boot?.remove();
    } else {
      window.setTimeout(finishBoot, 1500);
    }
    document.querySelector('[data-skip-boot]')?.addEventListener('click', finishBoot);
    window.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') finishBoot();
    });
  </script>
</BaseLayout>
